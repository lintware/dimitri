{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dimitri",
  "version": "0.1.0",
  "identifier": "dev.lintware.dimitri",
  "build": {
    "frontendDist": "../web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "Dimitri — Chemistry Harness",
        "width": 1500,
        "height": 950,
        "minWidth": 1000,
        "minHeight": 640
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "resources": ["vendor/**/*"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
    "category": "Education"
  }
}
